{"updatedAt":"2026-03-03T08:03:33.521Z","createdAt":"2026-03-03T06:11:54.785Z","id":"4MBLKBAFcbpccWrH","name":"Get API Token","description":null,"active":true,"isArchived":false,"nodes":[{"parameters":{"content":"## Get API Token\nShared sub-workflow. Obtains OAuth2 M2M token from Auth0.\nCaches token using workflow static data (TTL = 10 min).\n\n**Input:** `{ source: string }`\n**Output:** `{ source, token }` (empty string if auth disabled)","height":152,"width":780},"id":"f1000001-0000-4000-8000-000000000099","name":"Sticky Note","type":"n8n-nodes-base.stickyNote","typeVersion":1,"position":[-64,128]},{"parameters":{"workflowInputs":{"values":[{"name":"source"}]}},"id":"f1000001-0000-4000-8000-000000000001","name":"Trigger","type":"n8n-nodes-base.executeWorkflowTrigger","typeVersion":1.1,"position":[0,400]},{"parameters":{"conditions":{"options":{"version":2,"leftValue":"","caseSensitive":true,"typeValidation":"strict"},"combinator":"and","conditions":[{"id":"check-auth-enabled","operator":{"type":"string","operation":"equals"},"leftValue":"={{ $env.AUTH0_ENABLED }}","rightValue":"true"}]},"options":{}},"id":"f1000001-0000-4000-8000-000000000002","name":"Auth Enabled?","type":"n8n-nodes-base.if","typeVersion":2.2,"position":[224,400]},{"parameters":{"method":"POST","url":"={{ 'https://' + $env.AUTH0_DOMAIN + '/oauth/token' }}","sendBody":true,"specifyBody":"json","jsonBody":"={{ JSON.stringify({ grant_type: 'client_credentials', client_id: $env.JOB_HUNTER_API_M2M_AUTH0_CLIENT_ID, client_secret: $env.JOB_HUNTER_API_M2M_AUTH0_CLIENT_SECRET, audience: $env.JOB_HUNTER_API_AUTH0_AUDIENCE }) }}","options":{}},"id":"f1000001-0000-4000-8000-000000000003","name":"Get Token","type":"n8n-nodes-base.httpRequest","typeVersion":4.4,"position":[896,208],"onError":"continueErrorOutput"},{"parameters":{"jsCode":"const staticData = $getWorkflowStaticData('global');\nconst input = $('Trigger').first().json;\nconst token = $json.access_token;\n\nstaticData.token = token;\nstaticData.